# Frontend — only needed for local development (not needed in production)
VITE_ANTHROPIC_API_KEY=

# Backend URL — set this to your Railway URL in production
# Leave empty for local dev (uses direct API calls with browser key)
VITE_BACKEND_URL=

# Supabase Auth (optional)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
